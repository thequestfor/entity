OPENAI_API_KEY=

# Optional local LLM hot-drop configuration.
# Leave unset on machines without Ollama installed.
ENTITY_LOCAL_LLM_PROVIDER=
ENTITY_LOCAL_LLM_URL=http://localhost:11434
ENTITY_LOCAL_LLM_MODEL=
ENTITY_LOCAL_LLM_THINK=false

# Cloud model fallback. Keep disabled unless you explicitly want cloud use.
ENTITY_CLOUD_LLM_ENABLED=false
ENTITY_CLOUD_LLM_MODEL=gpt-4.1-mini

# TTS voice: kokoro or sam.
ENTITY_TTS_VOICE=kokoro

# Required only if ENTITY_TTS_VOICE=sam and engines/sam is not present.
ENTITY_SAM_PATH=
