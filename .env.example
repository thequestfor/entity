OPENAI_API_KEY=

# Optional local LLM hot-drop configuration.
# Leave unset on machines without Ollama installed.
ENTITY_LOCAL_LLM_PROVIDER=
ENTITY_LOCAL_LLM_URL=http://localhost:11434
ENTITY_LOCAL_LLM_MODEL=
ENTITY_LOCAL_LLM_THINK=false

# Optional local reasoning tier. If empty, Entity reuses ENTITY_LOCAL_LLM_MODEL
# with Ollama think=true when escalation is needed.
ENTITY_LOCAL_REASONING_LLM_MODEL=

# Cloud model fallback. Keep disabled unless you explicitly want cloud use.
ENTITY_CLOUD_LLM_ENABLED=false
ENTITY_CLOUD_LLM_MODEL=gpt-4.1-mini

# TTS voice: kokoro or sam.
ENTITY_TTS_VOICE=kokoro

# Required only if ENTITY_TTS_VOICE=sam and engines/sam is not present.
ENTITY_SAM_PATH=

# Optional plaintext phone/web interface through ntfy.
# Use long random topic names, especially when using public https://ntfy.sh.
ENTITY_NOTIFY_PROVIDER=
ENTITY_NTFY_URL=https://ntfy.sh
ENTITY_NTFY_OUT_TOPIC=
ENTITY_NTFY_IN_TOPIC=
# Strongly recommended for inbound commands, especially on public ntfy.sh.
ENTITY_NTFY_TOKEN=

# When true, Entity sends ntfy confirmations for durable/external actions such
# as creating calendar events, setting reminders, storing memories, changing
# presence, or learning behavior feedback.
ENTITY_NOTIFY_SIGNIFICANT_ACTIONS=true

# Optional Google Calendar integration.
ENTITY_GOOGLE_CALENDAR_ENABLED=false
ENTITY_GOOGLE_CALENDAR_ID=primary
ENTITY_GOOGLE_CREDENTIALS_PATH=agent/google_credentials.json
ENTITY_GOOGLE_TOKEN_PATH=agent/google_token.json
ENTITY_CALENDAR_DEFAULT_EVENT_MINUTES=60
ENTITY_CALENDAR_POLL_SECONDS=300
ENTITY_CALENDAR_LOOKAHEAD_HOURS=24
ENTITY_CALENDAR_ALERT_LEAD_MINUTES=30
ENTITY_TIMEZONE=America/New_York

# Optional route/departure alerts for upcoming calendar events.
# For live traffic travel time, use ENTITY_ROUTES_PROVIDER=tomtom.
# For basic route estimates without live traffic, use openrouteservice.
ENTITY_ROUTES_PROVIDER=
ENTITY_TOMTOM_API_KEY=
ENTITY_TOMTOM_BASE_URL=https://api.tomtom.com
ENTITY_OPENROUTESERVICE_API_KEY=
ENTITY_OPENROUTESERVICE_URL=https://api.heigit.org/openrouteservice
ENTITY_OPENROUTESERVICE_GEOCODE_URL=https://api.heigit.org/pelias/v1
ENTITY_HOME_ADDRESS=
# TomTom accepts car, truck, taxi, bus, van, motorcycle, bicycle, pedestrian.
# OpenRouteService accepts profiles like driving-car, cycling-regular, foot-walking.
ENTITY_DEFAULT_TRAVEL_MODE=driving-car
ENTITY_DEPARTURE_BUFFER_MINUTES=10
# Recheck traffic at this interval while an event is approaching.
ENTITY_ROUTE_REFRESH_SECONDS=900
# Do not spend route API quota before the event enters this horizon.
ENTITY_ROUTE_CHECK_HORIZON_HOURS=4

# Optional weather lookup through Open-Meteo. No API key required.
ENTITY_WEATHER_ENABLED=true
ENTITY_WEATHER_PROVIDER=open-meteo
ENTITY_WEATHER_USE_DETECTED_LOCATION=true
# Use either a city/state style default location or exact coordinates.
# Example: ENTITY_WEATHER_LOCATION=Austin, Texas
ENTITY_WEATHER_LOCATION=
# Coordinates are preferred when Entity usually runs from one place.
# Example: ENTITY_WEATHER_LATITUDE=30.2672
# Example: ENTITY_WEATHER_LONGITUDE=-97.7431
ENTITY_WEATHER_LATITUDE=
ENTITY_WEATHER_LONGITUDE=
ENTITY_WEATHER_TIMEOUT_SECONDS=10
ENTITY_OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
ENTITY_OPEN_METEO_GEOCODE_URL=https://geocoding-api.open-meteo.com/v1/search

# Optional current-location detection. Recognized Wi-Fi mappings stay local:
# NetworkManager's active connection name is compared with this allowlist and
# Entity does not scan, store, or upload nearby BSSIDs. Separate mappings with ||.
ENTITY_LOCATION_DETECTION_ENABLED=true
ENTITY_LOCATION_WIFI_MAPPING_ENABLED=true
ENTITY_LOCATION_WIFI_MAP=Home network name|Marvin, North Carolina|34.99182|-80.81479
# Coarse public-IP location sends a normal HTTPS request to the configured
# provider and is intentionally opt-in. It can be wrong by many miles.
ENTITY_LOCATION_PUBLIC_IP_ENABLED=false
ENTITY_LOCATION_PUBLIC_IP_URL=https://ipapi.co/json/
ENTITY_LOCATION_TIMEOUT_SECONDS=5

# Optional explicit internet research. Disabled by default.
ENTITY_RESEARCH_ENABLED=false
ENTITY_RESEARCH_MAX_RESULTS=3
ENTITY_RESEARCH_TIMEOUT_SECONDS=10
ENTITY_RESEARCH_STORE_BY_DEFAULT=false

# Optional continuous read-only world intelligence service. This is separate
# from explicit search and stores normalized public evidence in its own SQLite
# database. The initial collectors are USGS earthquakes, NASA EONET natural
# events, ReliefWeb humanitarian reports, GDACS disaster alerts, WHO outbreak
# notices, and U.S. National Weather Service alerts.
ENTITY_INTELLIGENCE_ENABLED=false
ENTITY_INTELLIGENCE_DB=agent/world_intelligence.db
ENTITY_INTELLIGENCE_WORKER_POLL_SECONDS=30
ENTITY_INTELLIGENCE_REQUEST_TIMEOUT_SECONDS=15
ENTITY_INTELLIGENCE_MAX_ITEMS_PER_SOURCE=50
ENTITY_FORECAST_MAX_ACTIVE=12
ENTITY_FORECAST_PER_CYCLE=2

# Delayed, bounded publisher calibration. Unverified reports are not penalized;
# only later independent confirmation, robust contradiction, or deletion without
# corroboration creates an outcome. Baseline trust is preserved separately.
ENTITY_REPUTATION_ENABLED=true
ENTITY_REPUTATION_MATURITY_HOURS=6
ENTITY_REPUTATION_MAX_ADJUSTMENT=0.15

# Localhost dashboard for collected public evidence.
ENTITY_INTELLIGENCE_DASHBOARD_ENABLED=true
ENTITY_INTELLIGENCE_DASHBOARD_HOST=127.0.0.1
ENTITY_INTELLIGENCE_DASHBOARD_PORT=8770

# Public-source controls. ReliefWeb requires an approved application name.
ENTITY_USGS_ENABLED=true
ENTITY_EONET_ENABLED=true
ENTITY_RELIEFWEB_ENABLED=true
ENTITY_RELIEFWEB_APPNAME=
ENTITY_GDACS_ENABLED=true
ENTITY_WHO_OUTBREAKS_ENABLED=true
# NWS coverage is primarily the United States and its territories.
ENTITY_NWS_ALERTS_ENABLED=true

# Direct publisher RSS/Atom feeds. Feed entries are separated by || and each
# entry is Publisher name|feed URL|baseline credibility. Entity stores feed
# metadata and links with attribution; it does not scrape full articles.
ENTITY_NEWS_ENABLED=true
ENTITY_NEWS_RSS_FEEDS=BBC News - World|https://feeds.bbci.co.uk/news/world/rss.xml|0.85||NPR - World|https://feeds.npr.org/1004/rss.xml|0.85
ENTITY_NEWS_POLL_SECONDS=300

# Public Gamma market data requires no account, API key, or wallet. Probabilities
# are retained as forecast signals and never count as factual corroboration.
ENTITY_POLYMARKET_ENABLED=true
ENTITY_POLYMARKET_POLL_SECONDS=300
ENTITY_POLYMARKET_MAX_MARKETS=50

# Free global news discovery through GDELT. GDELT indexes reports; it does not
# make every indexed publisher authoritative, so Entity assigns it lower trust.
# Separate queries with ||. It remains inactive until enabled and queries exist.
ENTITY_GDELT_ENABLED=false
ENTITY_GDELT_QUERIES=

# Read-only public Telegram channels through a dedicated local user session.
# Obtain API credentials at my.telegram.org. Never place login codes, account
# passwords, or two-step-verification passwords here.
ENTITY_TELEGRAM_ENABLED=false
ENTITY_TELEGRAM_API_ID=
ENTITY_TELEGRAM_API_HASH=
ENTITY_TELEGRAM_SESSION_PATH=agent/private/telegram_entity
# Comma-separated public usernames, without @. Private chats/groups are rejected.
ENTITY_TELEGRAM_CHANNELS=
ENTITY_TELEGRAM_POLL_SECONDS=120
ENTITY_TELEGRAM_MESSAGES_PER_CHANNEL=50
# Recently captured IDs checked for deletion on every cycle, per channel.
ENTITY_TELEGRAM_DELETION_SCAN_SIZE=100

# Private mail intelligence. These connectors use delegated read-only OAuth;
# never put an email password or Microsoft client secret in this file.
ENTITY_GMAIL_ENABLED=false
ENTITY_GMAIL_CREDENTIALS_PATH=agent/google_gmail_credentials.json
ENTITY_GMAIL_TOKEN_PATH=agent/google_gmail_token.json
ENTITY_GMAIL_QUERY=newer_than:7d -in:spam -in:trash

ENTITY_OUTLOOK_ENABLED=false
ENTITY_OUTLOOK_CLIENT_ID=
# common supports personal Microsoft accounts and work/school accounts.
ENTITY_OUTLOOK_TENANT=common
ENTITY_OUTLOOK_TOKEN_CACHE_PATH=agent/outlook_mail_token_cache.json
ENTITY_OUTLOOK_FOLDER=inbox

# False stores subject, sender, labels/categories, and provider preview only.
# True also stores up to 20,000 normalized characters of each message body.
ENTITY_MAIL_STORE_BODY=false

# Read-only public X signals. X API usage is currently pay-per-use; configure
# credits and a spending limit in the X Developer Console before enabling.
ENTITY_X_ENABLED=false
ENTITY_X_BEARER_TOKEN=
# Comma-separated handles without passwords. Leading @ is optional.
ENTITY_X_USERNAMES=
# Separate recent-search queries with || (each query may contain spaces/operators).
ENTITY_X_SEARCH_QUERIES=
ENTITY_X_POLL_SECONDS=900
ENTITY_X_MAX_RESULTS=25

# Confirmation flow for uncertain or sensitive planner actions.
ENTITY_CONFIRMATION_TTL_SECONDS=600

# Autonomous self-maintenance loop. This checks service health and pending
# confirmations without waiting for a user prompt.
ENTITY_AUTONOMY_ENABLED=true
ENTITY_AUTONOMY_INITIAL_DELAY_SECONDS=60
ENTITY_AUTONOMY_POLL_SECONDS=900
ENTITY_AUTONOMY_ALERT_REPEAT_SECONDS=3600
ENTITY_AUTONOMOUS_GOALS_ENABLED=true

# Guaranteed once-per-day local briefing. The autonomy observer checks this
# schedule and delivers through configured notifications and speech when present.
ENTITY_DAILY_BRIEFING_ENABLED=true
ENTITY_DAILY_BRIEFING_HOUR=7
ENTITY_DAILY_BRIEFING_MINUTE=30
# If Entity starts late, deliver within this many hours after the scheduled time.
ENTITY_DAILY_BRIEFING_GRACE_HOURS=4

# Periodic reflection turns recent logs into durable learning memories.
ENTITY_REFLECTION_ENABLED=true
ENTITY_REFLECTION_INTERVAL_SECONDS=86400

# Visual interface selected when main.py is run without an explicit mode.
# Choices: 2d, 3d, unreal. Web modes bind to localhost by default.
ENTITY_VISUAL_MODE=2d
ENTITY_VISUAL_HOST=127.0.0.1
ENTITY_VISUAL_PORT=8765
ENTITY_VISUAL_OPEN_BROWSER=true

# Optional Unreal Editor proof-of-concept visual bridge. Unreal's Remote
# Control API must be enabled and its HTTP server must be running.
ENTITY_UNREAL_ENABLED=false
# Prefer cloud inference while Unreal is reachable, preserving local fallback.
ENTITY_PREFER_CLOUD_WHEN_UNREAL=false
ENTITY_UNREAL_REMOTE_URL=http://127.0.0.1:30010
ENTITY_UNREAL_PRESET=EntityOrb
ENTITY_UNREAL_TARGET=component_scalar
ENTITY_UNREAL_COMPONENT_PATH=/Game/Maps/UEDPIE_0_EntityRoomTest.EntityRoomTest:PersistentLevel.BP_EntityOrb_C_0.Shell
# Legacy preset-property mode remains available for simple editor properties.
ENTITY_UNREAL_PROPERTY=Entity State
# Function mode remains available for native remotely-callable functions.
ENTITY_UNREAL_FUNCTION=SetEntityState
ENTITY_UNREAL_STATE_PARAMETER=NewState
ENTITY_UNREAL_TIMEOUT_SECONDS=0.5
