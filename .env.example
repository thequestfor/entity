OPENAI_API_KEY=

# Optional local LLM hot-drop configuration.
# Leave unset on machines without Ollama installed.
ENTITY_LOCAL_LLM_PROVIDER=
ENTITY_LOCAL_LLM_URL=http://localhost:11434
ENTITY_LOCAL_LLM_MODEL=
ENTITY_LOCAL_LLM_THINK=false

# Optional local reasoning tier. If empty, Entity reuses ENTITY_LOCAL_LLM_MODEL
# with Ollama think=true when escalation is needed.
ENTITY_LOCAL_REASONING_LLM_MODEL=

# Cloud model fallback. Keep disabled unless you explicitly want cloud use.
ENTITY_CLOUD_LLM_ENABLED=false
ENTITY_CLOUD_LLM_MODEL=gpt-4.1-mini

# TTS voice: kokoro or sam.
ENTITY_TTS_VOICE=kokoro

# Required only if ENTITY_TTS_VOICE=sam and engines/sam is not present.
ENTITY_SAM_PATH=

# Optional plaintext phone/web interface through ntfy.
# Use long random topic names, especially when using public https://ntfy.sh.
ENTITY_NOTIFY_PROVIDER=
ENTITY_NTFY_URL=https://ntfy.sh
ENTITY_NTFY_OUT_TOPIC=
ENTITY_NTFY_IN_TOPIC=
ENTITY_NTFY_TOKEN=

# Optional Google Calendar integration.
ENTITY_GOOGLE_CALENDAR_ENABLED=false
ENTITY_GOOGLE_CALENDAR_ID=primary
ENTITY_GOOGLE_CREDENTIALS_PATH=agent/google_credentials.json
ENTITY_GOOGLE_TOKEN_PATH=agent/google_token.json
ENTITY_CALENDAR_DEFAULT_EVENT_MINUTES=60
ENTITY_CALENDAR_POLL_SECONDS=300
ENTITY_CALENDAR_LOOKAHEAD_HOURS=24
ENTITY_CALENDAR_ALERT_LEAD_MINUTES=30
ENTITY_TIMEZONE=America/New_York

# Optional route/departure alerts for upcoming calendar events.
ENTITY_ROUTES_PROVIDER=
ENTITY_OPENROUTESERVICE_API_KEY=
ENTITY_OPENROUTESERVICE_URL=https://api.openrouteservice.org
ENTITY_HOME_ADDRESS=
ENTITY_DEFAULT_TRAVEL_MODE=driving-car
ENTITY_DEPARTURE_BUFFER_MINUTES=10
